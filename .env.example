# Domain target yang akan di-mirror
TARGET_DOMAIN=nintendoeverything.com

# Domain mirror kamu (ganti dengan domain kamu)
MIRROR_DOMAIN=nintendoeverything.net

# Port server (Railway/Render akan set PORT otomatis)
PORT=3000

# Cache TTL dalam detik
CACHE_TTL_HTML=600
CACHE_TTL_SITEMAP=3600
CACHE_TTL_STATIC=86400

# User agent untuk request ke upstream
USER_AGENT=Mozilla/5.0 (compatible; MirrorProxy/1.0)
